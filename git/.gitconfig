[user]
  name = Kevin
  email = jkevincodes@gmail.com

[color]
  ui = true

[core]
  excludefiles = ~/.gitignore-global
  editor = nvim

[difftool]
  prompt = true

[difftool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""

[merge]
  tool = nvimdiff
  conflictstyle = diff3

[diff]
  tool = nvimdiff

[credential "https://github.com"]
  helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
  helper = !/usr/bin/gh auth git-credential
